<Window x:Class="CirclePointDistributorInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CirclePointDistributorInstaller"
        mc:Ignorable="d"
        Title="Instalador - D2BASE" Height="300" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Icon="Resources/icon.png">
    <Window.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Instalar D2BASE" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>
            
            <TextBlock Text="Local de Instalação:" Margin="0,0,0,5" Foreground="#666"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InstallPathTxt" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                <Button Grid.Column="1" Content="..." Width="40" Margin="10,0,0,0" Click="BrowseBtn_Click" Style="{StaticResource ModernButtonStyle}"/>
            </Grid>
            
            <Button x:Name="InstallBtn" Content="Instalar Aplicativo" HorizontalAlignment="Right" Click="InstallBtn_Click" Style="{StaticResource ModernButtonStyle}"/>

            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,20,0,0">
                <TextBlock x:Name="StatusTxt" Text="Instalando..." Margin="0,0,0,5"/>
                <ProgressBar x:Name="InstallProgress" Height="20" IsIndeterminate="True"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
